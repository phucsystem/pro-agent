# Required
AUTH_TOKEN=your-long-lived-token-here
LLM_API_KEY=sk-xxx

# LLM Provider — LiteLLM uses "{LLM_PROVIDER}/{LLM_MODEL}" format automatically
# DeepSeek Chat (default):
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# DeepSeek Reasoner (R1 — returns <think>...</think> blocks):
# LLM_MODEL=deepseek-reasoner

# OpenRouter example (model already prefixed, leave LLM_BASE_URL blank):
# LLM_PROVIDER=openrouter
# LLM_MODEL=openrouter/deepseek/deepseek-chat
# LLM_BASE_URL=https://openrouter.ai/api/v1

# OpenAI example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=

# LLM timeout (seconds) — prevents hanging on slow providers
# LLM_TIMEOUT=60

# Server
PORT=8000
POSTGRES_URL=postgresql://agent:agent@localhost:5432/pro_agent

# DB connection pool
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_STATEMENT_TIMEOUT=30

# Multi-agent isolation (optional — prefix all table names)
# TABLE_PREFIX=agent1_

# Embedding config
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
# EMBEDDING_API_KEY=        # falls back to LLM_API_KEY if unset
# EMBEDDING_API_BASE=       # custom base URL (e.g., for Ollama)

# Langfuse (optional — disable if unset)
LANGFUSE_PUBLIC_KEY=pk-xxx
LANGFUSE_SECRET_KEY=sk-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Tool-specific (Phase 2)
GITHUB_TOKEN=ghp-xxx
SEARCH_API_KEY=xxx
FILE_IO_SANDBOX_DIR=/app/sandbox
